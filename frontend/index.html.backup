const LANG_TO_API = { en:'English', nl:'Dutch', es:'Spanish', pt:'Portuguese', fr:'French' };

function applyTranslations(lang) {
  const t = T[lang] || T.en;
  currentLang = lang;
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.getAttribute('data-i18n');
    if (t[key] !== undefined) el.innerHTML = t[key];
  });
  document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
    const key = el.getAttribute('data-i18n-placeholder');
    if (t[key] !== undefined) el.placeholder = t[key];
  });
  document.getElementById('html-root').lang = lang;
  const planType = document.querySelector('input[name=plan_type]:checked')?.value || 'grant';
  updateFinancialPlaceholder(planType, t);
  const outputLangMap = { en:'English', nl:'Dutch', es:'Spanish', pt:'Portuguese', fr:'French' };
  document.getElementById('outputLang').value = outputLangMap[lang] || 'English';
}

function updateFinancialPlaceholder(planType, t) {
  const ph = t[`ph_financial_${planType}`] || t.ph_financial_grant || '';
  if (ph) document.getElementById('financial_expectations').placeholder = ph;
}

function switchLanguage(lang) { applyTranslations(lang); }

function selectPlanType(type, el) {
  document.querySelectorAll('.plan-type-card').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
  document.getElementById('bank-extra').style.display = type === 'bank' ? 'flex' : 'none';
  updateFinancialPlaceholder(type, T[currentLang] || T.en);
}

const stepOrder = ['intake','grants','market','writing','financial','compliance','assembly'];
let stepIndex = 0, stepTimer = null;

function startStepAnimation() {
  stepIndex = 0;
  stepOrder.forEach(s => { document.getElementById('step-'+s).className = 'pipeline-step'; });
  advanceStep();
}
function advanceStep() {
  if (stepIndex >= stepOrder.length) return;
  if (stepIndex > 0) document.getElementById('step-'+stepOrder[stepIndex-1]).className = 'pipeline-step done';
  document.getElementById('step-'+stepOrder[stepIndex]).className = 'pipeline-step active';
  stepIndex++;
  const delays = [4000,8000,12000,18000,10000,8000,4000];
  stepTimer = setTimeout(advanceStep, delays[stepIndex-1] || 8000);
}
function stopStepAnimation() {
  clearTimeout(stepTimer);
  stepOrder.forEach(s => { document.getElementById('step-'+s).className = 'pipeline-step done'; });
}

let currentThreadId = null;

async function generatePlan() {
  const t = T[currentLang] || T.en;
  const required = ['business_name','startup_idea','industry','location','target_customers','financial_expectations'];
  for (const id of required) {
    if (!document.getElementById(id).value.trim()) {
      showError(t.err_required);
      document.getElementById(id).focus();
      return;
    }
  }
  hideError();
  businessName = document.getElementById('business_name').value.trim();
  const planType = document.querySelector('input[name=plan_type]:checked')?.value || 'grant';
  const outputLang = document.getElementById('outputLang').value;
  document.getElementById('generateBtn').disabled = true;
  document.getElementById('btnText').textContent = '…';
  document.getElementById('loadingCard').classList.add('visible');
  document.getElementById('resultCard').classList.remove('visible');
  document.getElementById('reviewPanel1').classList.remove('visible');
  document.getElementById('reviewPanel2').classList.remove('visible');
  startStepAnimation();
  const payload = {
    business_name: document.getElementById('business_name').value.trim(),
    startup_idea: document.getElementById('startup_idea').value.trim(),
    industry: document.getElementById('industry').value,
    location: document.getElementById('location').value.trim(),
    target_customers: document.getElementById('target_customers').value.trim(),
    financial_expectations: document.getElementById('financial_expectations').value.trim(),
    founder_background: document.getElementById('founder_background').value.trim(),
    plan_type: planType,
    language: outputLang,
  };
  try {
    const res = await fetch(`${API_BASE}/generate/start`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    if (!res.ok) { const err = await res.json(); throw new Error(err.detail || `Server error ${res.status}`); }
    const data = await res.json();
    stopStepAnimation();
    document.getElementById('loadingCard').classList.remove('visible');
    if (data.status === 'checkpoint') {
      currentThreadId = data.thread_id;
      showCheckpoint(data);
    } else {
      showResult(data, planType, outputLang);
    }
  } catch (err) {
    stopStepAnimation();
    document.getElementById('loadingCard').classList.remove('visible');
    // Fallback to original /generate endpoint if /generate/start not available
    try {
      const res2 = await fetch(`${API_BASE}/generate`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res2.ok) { const e2 = await res2.json(); throw new Error(e2.detail || `Server error ${res2.status}`); }
      const data2 = await res2.json();
      showResult(data2, planType, outputLang);
    } catch (err2) {
      showError(`${t.err_connect} ${API_BASE}. (${err2.message})`);
    }
  } finally {
    document.getElementById('generateBtn').disabled = false;
    document.getElementById('btnText').innerHTML = (T[currentLang]||T.en).btn_generate;
  }
}

function showCheckpoint(data) {
  // Hide loading card first
  document.getElementById('loadingCard').classList.remove('visible');
  // Hide both panels first
  document.getElementById('reviewPanel1').classList.remove('visible');
  document.getElementById('reviewPanel2').classList.remove('visible');
  const panel = data.checkpoint === 1 ? 'reviewPanel1' : 'reviewPanel2';
  const review = data.review_data || {};
  if (data.checkpoint === 1) {
    document.getElementById('r1_market_size').value    = review.market_size || '';
    document.getElementById('r1_competitors').value    = review.competitor_overview || '';
    document.getElementById('r1_customers').value      = review.target_customer_analysis || '';
    const grantsEl = document.getElementById('r1_grants');
    grantsEl.innerHTML = '';
    const grants = review.best_matching_grants || [];
    if (grants.length) {
      grants.forEach(g => {
        const name = g.name || g.grant_name || 'Grant';
        grantsEl.innerHTML += `<span class="review-grant-tag">${name}</span>`;
      });
    } else {
      grantsEl.innerHTML = '<span style="color:var(--color-text-hint);font-size:12px">No specific grants matched yet — will search further after review.</span>';
    }
  } else {
    ['executive_summary','problem_statement','solution','market_opportunity',
     'business_model','marketing_strategy','operations_plan','funding_request'].forEach(f => {
      const el = document.getElementById('r2_' + f);
      if (el) el.value = review[f] || '';
    });
  }
  document.getElementById(panel).classList.add('visible');
  document.getElementById(panel).scrollIntoView({ behavior: 'smooth', block: 'start' });
}

async function approveCheckpoint(checkpointNum, edits) {
  const t = T[currentLang] || T.en;
  const planType = document.querySelector('input[name=plan_type]:checked')?.value || 'grant';
  const outputLang = document.getElementById('outputLang').value;
  const btn = document.getElementById(checkpointNum === 1 ? 'reviewPanel1' : 'reviewPanel2').querySelector('.btn-review-approve');
  btn.disabled = true;
  btn.textContent = 'Processing…';
  document.getElementById('loadingCard').classList.add('visible');
  document.getElementById('reviewPanel1').classList.remove('visible');
  document.getElementById('reviewPanel2').classList.remove('visible');
  startStepAnimation();
  try {
    const res = await fetch(`${API_BASE}/generate/resume`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ thread_id: currentThreadId, checkpoint: checkpointNum, approved: true, edits }),
    });
    if (!res.ok) { const err = await res.json(); throw new Error(err.detail || `Server error ${res.status}`); }
    const data = await res.json();
    stopStepAnimation();
    document.getElementById('loadingCard').classList.remove('visible');
    if (data.status === 'checkpoint') {
      showCheckpoint(data);
    } else {
      showResult(data, planType, outputLang);
    }
  } catch (err) {
    stopStepAnimation();
    document.getElementById('loadingCard').classList.remove('visible');
    showError('Resume error: ' + err.message);
  } finally {
    btn.disabled = false;
    btn.textContent = checkpointNum === 1 ? 'Approve & Continue to Plan Writing' : 'Approve & Generate Final Plan';
  }
}

function approveCheckpoint1() {
  const edits = {
    market_size:              document.getElementById('r1_market_size').value.trim(),
    competitor_overview:      document.getElementById('r1_competitors').value.trim(),
    target_customer_analysis: document.getElementById('r1_customers').value.trim(),
  };
  approveCheckpoint(1, edits);
}

function approveCheckpoint2() {
  const edits = {};
  ['executive_summary','problem_statement','solution','market_opportunity',
   'business_model','marketing_strategy','operations_plan','funding_request'].forEach(f => {
    const el = document.getElementById('r2_' + f);
    if (el && el.value.trim()) edits[f] = el.value.trim();
  });
  approveCheckpoint(2, edits);
}

function showResult(data, planType, outputLang) {
  document.getElementById('loadingCard').classList.remove('visible');
  const t = T[currentLang] || T.en;
  generatedPlan = data.final_plan || '';
  const score = Math.round((data.compliance_score || 0) * 100);
  const revs  = data.revision_count || 0;
  const time  = data.processing_time_seconds || 0;
  const ptLabel = t.pt_labels[planType] || planType;
  const revWord = revs === 1 ? t.revision : t.revisions;
  document.getElementById('resultTitle').textContent = `${data.business_name || businessName} — ${t.plan_ready}`;
  document.getElementById('resultMeta').textContent  = `${ptLabel} · ${outputLang} · ${t.generated_in} ${time}${t.seconds} · ${revs} ${revWord} ${t.completed}`;
  document.getElementById('scoreText').textContent   = `${t.score_label}: ${score}%`;
  document.getElementById('planOutput').textContent  = generatedPlan;
  const grantsGrid = document.getElementById('grantsGrid');
  grantsGrid.innerHTML = '';
  const grants = data.grants_matched || [];
  if (!grants.length) {
    grantsGrid.innerHTML = `<p style="color:rgba(255,255,255,0.35);font-size:14px">No grants matched for this profile.</p>`;
  } else {
    grants.forEach(g => {
      const pct = Math.round((g.match_score||0)*100);
      const criteria = (g.eligibility_criteria||[]).slice(0,3);
      grantsGrid.innerHTML += `
        <div class="grant-card">
          <div class="grant-card-top">
            <div><div class="grant-name">${g.name||'Grant'}</div><div class="grant-provider">${g.provider||''}</div></div>
            <div class="grant-amount">${g.formatted_amount || ('USD ' + (g.max_amount_usd||0).toLocaleString())}</div>
          </div>
          <div class="grant-match">
            <div class="match-bar-bg"><div class="match-bar-fill" style="width:${pct}%"></div></div>
            <div class="match-pct">${pct}% match</div>
          </div>
          <div class="grant-criteria">${criteria.map(c=>`<span class="criteria-tag">${c}</span>`).join('')}</div>
        </div>`;
    });
  }
  document.getElementById('resultCard').classList.add('visible');
  document.getElementById('resultCard').scrollIntoView({ behavior:'smooth', block:'start' });
}

function showTab(name, btn) {
  document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  btn.classList.add('active');
}

function downloadPlan() {
  const blob = new Blob([generatedPlan], { type:'text/plain' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `${businessName.replace(/\s+/g,'_')}_Business_Plan.txt`;
  a.click();
}
function copyPlan() {
  const t = T[currentLang] || T.en;
  navigator.clipboard.writeText(generatedPlan).then(() => {
    const btn = document.getElementById('copyBtn');
    btn.textContent = t.copied;
    setTimeout(() => btn.innerHTML = t.btn_copy, 2000);
  });
}
function resetForm() {
  document.getElementById('resultCard').classList.remove('visible');
  document.getElementById('formCard').scrollIntoView({ behavior:'smooth' });
  generatedPlan = '';
}
function showError(msg) {
  const box = document.getElementById('errorBox');
  box.textContent = msg;
  box.classList.add('visible');
  box.scrollIntoView({ behavior:'smooth', block:'nearest' });
}
function hideError() { document.getElementById('errorBox').classList.remove('visible'); }

applyTranslations('en');
document.addEventListener('keydown', e => { if (e.key==='Enter' && e.ctrlKey) generatePlan(); });

const MOON_SVG = `<svg id="themeIcon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>`;
const SUN_SVG  = `<svg id="themeIcon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`;

function toggleTheme() {
  const isLight = document.documentElement.classList.toggle('light');
  document.getElementById('themeToggle').innerHTML = isLight ? SUN_SVG : MOON_SVG;
  localStorage.setItem('gb_theme', isLight ? 'light' : 'dark');
}
(function initTheme() {
  const saved = localStorage.getItem('gb_theme');
  if (saved === 'light') {
    document.documentElement.classList.add('light');
    const btn = document.getElementById('themeToggle');
    if (btn) btn.innerHTML = SUN_SVG;
  }
})();
</script>
</body>
</html>
